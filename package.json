{
  "name": "black-desert-idle",
  "version": "0.1.0",
  "private": true,
  "description": "Browser-based idle game inspired by Black Desert Online.",
  "scripts": {
    "build": "python3 scripts/build.py",
    "check-build": "python3 scripts/check_build_freshness.py",
    "check-i18n": "node scripts/check-missing-translations.js",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "serve": "python3 -m http.server 8000"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "csso-cli": "^4.0.2",
    "terser": "^5.49.0"
  }
}
